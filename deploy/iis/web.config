<?xml version="1.0" encoding="UTF-8"?>
<!--
  web.config — Reverse proxy IIS para Controle de Ativos
  ========================================================
  Pre-requisitos no Windows Server:
    - IIS com modulo "URL Rewrite" instalado
    - IIS com modulo "Application Request Routing (ARR)" instalado
      (download: https://www.iis.net/downloads/microsoft/application-request-routing)
    - ARR habilitado como proxy: IIS Manager > servidor > ARR > Server Proxy Settings > Enable proxy

  Funcionamento:
    O IIS recebe requisicoes na porta 80 (e 443 com TLS) e encaminha
    para o Waitress rodando em 127.0.0.1:8000.

  Instalacao:
    Copie este arquivo para a raiz do site no IIS (ex: C:\controle_ativos\)
    ou aponte o site IIS para a pasta do projeto.
-->
<configuration>
  <system.webServer>

    <!-- Remove cabecalho Server do IIS para nao expor versao -->
    <security>
      <requestFiltering>
        <!-- Limite de upload alinhado com MAX_CONTENT_LENGTH do Flask (10 MB) -->
        <requestLimits maxAllowedContentLength="10485760" />
      </requestFiltering>
    </security>

    <!-- =========================================================
         Headers de segurança globais
         ========================================================= -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <add name="X-Content-Type-Options"  value="nosniff" />
        <add name="X-Frame-Options"         value="DENY" />
        <add name="Referrer-Policy"         value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy"      value="geolocation=(), camera=(), microphone=()" />
        <add name="Content-Security-Policy" value="default-src 'self'; style-src 'self' https://cdn.jsdelivr.net; font-src 'self' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline'; img-src 'self' data:;" />
      </customHeaders>
    </httpProtocol>

    <!-- =========================================================
         Reverse proxy para Waitress (porta 8000)
         ========================================================= -->
    <rewrite>
      <rules>
        <!-- Redireciona HTTP para HTTPS (descomente quando certificado estiver instalado)
             Quando HTTPS estiver ativo no IIS, esta rule força todas as requisicoes
             para protocolo seguro.
        -->
        <rule name="Force HTTPS" stopProcessing="true" enabled="false">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}" redirectType="Permanent" />
        </rule>

        <!-- Define X-Forwarded-Proto corretamente para HTTPS.
             Nota: {HTTPS} retorna "on"/"off", mas ProxyFix do Werkzeug espera "https"/"http".
             Sem esta conversão, Flask vê HTTPS=off mesmo quando a conexão IIS→Cliente é HTTPS.
        -->
        <rule name="Set-Proto-HTTPS" stopProcessing="false">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="on" />
          </conditions>
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="None" />
        </rule>

        <!-- Define X-Forwarded-Proto corretamente para HTTP. -->
        <rule name="Set-Proto-HTTP" stopProcessing="false">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="off" />
          </conditions>
          <serverVariables>
            <set name="HTTP_X_FORWARDED_FOR"   value="{REMOTE_ADDR}" />
            <set name="HTTP_X_FORWARDED_PROTO" value="http" />
            <set name="HTTP_X_REAL_IP"         value="{REMOTE_ADDR}" />
          </serverVariables>
          <action type="None" />
        </rule>

        <!-- Bloqueia acesso direto a uploads via URL estatica -->
        <rule name="Bloquear uploads diretos" stopProcessing="true">
          <match url="^static/uploads/" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Acesso nao permitido" />
        </rule>

        <!-- Proxy reverso para o Waitress -->
        <rule name="Proxy para Waitress" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:8000/{R:1}" />
        </rule>
      </rules>
    </rewrite>

    <!-- =========================================================
         Cache de arquivos estaticos (se servidos diretamente pelo IIS)
         ========================================================= -->
    <staticContent>
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="30.00:00:00" />
    </staticContent>

  </system.webServer>
</configuration>
