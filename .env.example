# Host do servidor MySQL.
DB_HOST=localhost

# Porta TCP do MySQL.
DB_PORT=3306

# Usuário dedicado da aplicação.
DB_USER=opus_app

# Senha do usuário dedicado da aplicação.
DB_PASSWORD=CHANGE_ME

# Nome do banco de dados utilizado pelo sistema.
DB_NAME=controle_ativos

# Chave secreta do Flask para sessão e segurança de cookies.
FLASK_SECRET_KEY=CHANGE_ME

# Pepper adicional usado em rotinas de segurança da aplicação.
APP_PEPPER=CHANGE_ME

# Mantém o Flask em modo seguro por padrão no clone inicial.
FLASK_DEBUG=0

# Em desenvolvimento local pode ficar em 0; em HTTPS real use 1.
SESSION_COOKIE_SECURE=0

# Tempo de vida da sessão autenticada, em minutos.
SESSION_LIFETIME_MINUTES=120

# Limites de segurança do login.
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Nível de log da aplicação.
LOG_LEVEL=INFO

# Diretório de logs relativo ao projeto.
LOG_DIR=logs

# Número de iterações do PBKDF2 para hash de senha.
# 600000 é o padrão seguro (OWASP 2024). Aumentar reduz velocidade de brute-force.
PBKDF2_ITERATIONS=600000

# Tipo de armazenamento de arquivos (anexos de ativos).
# "local" para desenvolvimento/Windows Server (filesystem local)
# "s3" para Render/cloud (Amazon S3, Cloudflare R2, Backblaze B2, etc.)
STORAGE_TYPE=local

# Parâmetros de S3 (obrigatórios se STORAGE_TYPE=s3).
# S3_BUCKET: nome do bucket
S3_BUCKET=CHANGE_ME

# S3_REGION: região AWS (ex: us-east-1, eu-west-1)
S3_REGION=us-east-1

# S3_ACCESS_KEY_ID: chave de acesso
S3_ACCESS_KEY_ID=CHANGE_ME

# S3_SECRET_ACCESS_KEY: chave secreta
S3_SECRET_ACCESS_KEY=CHANGE_ME

# S3_ENDPOINT_URL: URL customizada para S3-compatível (R2, B2, etc.)
# Deixe vazio para usar AWS S3 padrão
S3_ENDPOINT_URL=

# Timeout para conexão com banco de dados (segundos).
# Aumentar se usar conexão remota lenta ou cold-start em Render.
DB_CONNECTION_TIMEOUT=30

# Proxy reverso confiável (Cloudflare Tunnel, IIS, Nginx, etc.).
# Ativar apenas em produção quando há um proxy na frente do Waitress.
# Habilita middleware ProxyFix que reconstitui IP real e protocolo HTTPS a partir dos
# headers X-Forwarded-For, X-Forwarded-Proto, X-Forwarded-Host.
# Desenvolvimento: deixar em 0
# Produção com Cloudflare Tunnel: configurar em 1
PROXY_FIX_ENABLED=0

# Número de proxies que adicionam X-Forwarded-For.
# Cloudflare Tunnel direto para Waitress: 1
# IIS → Cloudflare Tunnel (duplo proxy): 2
PROXY_FIX_X_FOR=1

# Número de proxies que adicionam X-Forwarded-Proto.
# Geralmente igual a X_FOR.
PROXY_FIX_X_PROTO=1

# Número de proxies que adicionam X-Forwarded-Host.
# Deixar em 0 (não confiar em X-Forwarded-Host por padrão).
PROXY_FIX_X_HOST=0

# Scheme (http/https) usado por Flask para gerar URLs e redirecionamentos via url_for().
# Essencial em produção atrás de proxy reverso HTTPS (Cloudflare Tunnel).
# Desenvolvimento: http (padrão, HTTP local)
# Produção com Cloudflare Tunnel: https (obrigatório para urls/redirects corretos)
PREFERRED_URL_SCHEME=https

# Hostname para validações e redirecionamentos do Flask.
# Deixar vazio em desenvolvimento local.
# Em produção com Cloudflare Tunnel, configure com o domínio público.
# Exemplo: sistema.empresa.com
SERVER_NAME=
